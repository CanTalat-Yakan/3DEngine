@using Editor.Shell
@using Microsoft.JSInterop


@foreach (var el in Elements)
{
    switch (el.Tag)
    {
        // ── Text & Display ──────────────────────────────────────────
        case "text":
            <span class="@el.Css">@el.Text</span>
            break;

        case "h1":
            <h1 class="@Cx("text-4xl font-bold tracking-tight sm:text-5xl", el.Css)">@el.Text</h1>
            break;
        case "h2":
            <h2 class="@Cx("text-4xl font-bold tracking-tight sm:text-5xl", el.Css)">@el.Text</h2>
            break;
        case "h3":
            <h3 class="@Cx("text-xl font-semibold", el.Css)">@el.Text</h3>
            break;
        case "h4":
            <h4 class="@Cx("text-lg font-semibold", el.Css)">@el.Text</h4>
            break;
        case "h5" or "h6":
            <h5 class="@Cx("text-sm font-medium", el.Css)">@el.Text</h5>
            break;

        case "p":
            <p class="@Cx("text-xl text-muted-foreground", el.Css)">@el.Text</p>
            break;

        case "label":
            <BbLabel For="@el.Id" class="@el.Css">@el.Text</BbLabel>
            break;

        case "icon":
            {
                var iconName = PropIcon(el, "icon");
                var iconSize = PropInt(el, "size", 16);
                @RenderIcon(iconName, iconSize, el.Css)
            }
            break;

        case "badge":
            {
                var v = PropStr(el, "variant");
                var bv = v switch
                {
                    "secondary" => BadgeVariant.Secondary,
                    "outline" => BadgeVariant.Outline,
                    "destructive" => BadgeVariant.Destructive,
                    _ => BadgeVariant.Default
                };
                <BbBadge Variant="bv" class="@el.Css">@el.Text</BbBadge>
            }
            break;

        case "code":
            <code class="@Cx("rounded bg-muted px-1.5 py-0.5 font-mono text-sm", el.Css)">@el.Text</code>
            break;

        case "avatar":
            <BbAvatar class="@el.Css">
                <BbAvatarFallback>@el.Text</BbAvatarFallback>
            </BbAvatar>
            break;

        case "progress":
            {
                var pVal = PropInt(el, "value");
                <BbProgress Value="pVal" class="@el.Css" />
            }
            break;

        case "skeleton":
            {
                var skW = PropStr(el, "width");
                var skH = PropStr(el, "height");
                var skStyle = "";
                if (skW != null) skStyle += $"width:{skW};";
                if (skH != null) skStyle += $"height:{skH};";
                <BbSkeleton class="@el.Css" style="@(skStyle.Length > 0 ? skStyle : null)" />
            }
            break;

        case "spinner":
            {
                var spSize = PropInt(el, "size", 16);
                var spSz = spSize <= 12 ? SpinnerSize.Small : spSize >= 24 ? SpinnerSize.Large : SpinnerSize.Default;
                <BbSpinner Size="spSz" class="@el.Css" />
            }
            break;

        case "kbd":
            <BbKbd class="@el.Css">@el.Text</BbKbd>
            break;

        // ── Interactive ─────────────────────────────────────────────
        case "button":
            {
                var v = PropStr(el, "variant");
                var bv = MapButtonVariant(v);
                var ic = PropIcon(el, "icon");
                var btnDisabled = PropBool(el, "disabled");
                var btnLoading = PropBool(el, "loading");
                var btnHref = PropStr(el, "href");
                @if (btnHref != null)
                {
                    <BbButton Variant="bv" class="@el.Css" Href="@btnHref" Disabled="btnDisabled">
                        @if (ic != null) { @RenderIcon(ic, 16, "mr-2") }
                        @el.Text
                    </BbButton>
                }
                else
                {
                    <BbButton Variant="bv" class="@el.Css" @onclick="() => el.OnClick?.Invoke()"
                              Disabled="btnDisabled" Loading="btnLoading">
                        @if (ic != null) { @RenderIcon(ic, 16, "mr-2") }
                        @el.Text
                    </BbButton>
                }
            }
            break;

        case "input":
            {
                var ph = PropStr(el, "placeholder");
                var val = PropStr(el, "value") ?? "";
                <BbInput Placeholder="@ph" Value="@val" id="@el.Id" class="@el.Css"
                         ValueChanged="v => el.OnInput?.Invoke(v)" UpdateTiming="UpdateTiming.Immediate" />
            }
            break;

        case "textarea":
            {
                var taEl = el;
                var taPh = PropStr(taEl, "placeholder");
                var taVal = PropStr(taEl, "value") ?? "";
                <BbTextarea Placeholder="@taPh" Value="@taVal" id="@taEl.Id" class="@taEl.Css"
                            ValueChanged="@(v => taEl.OnInput?.Invoke(v))" />
            }
            break;

        case "checkbox":
            {
                var cbEl = el;
                var cbChk = PropBool(cbEl, "checked");
                <div class="@Cx("flex items-center space-x-2", cbEl.Css)">
                    <BbCheckbox id="@cbEl.Id" Checked="cbChk"
                                CheckedChanged="@(v => OnCheckedChanged(cbEl, v))" />
                    @if (cbEl.Text != null) { <BbLabel For="@cbEl.Id" class="font-normal">@cbEl.Text</BbLabel> }
                </div>
            }
            break;

        case "switch":
            {
                var swEl = el;
                var swChk = PropBool(swEl, "checked");
                <div class="@Cx("flex items-center space-x-2", swEl.Css)">
                    <BbSwitch id="@swEl.Id" Checked="swChk"
                              CheckedChanged="@(v => OnCheckedChanged(swEl, v))" />
                    @if (swEl.Text != null) { <BbLabel For="@swEl.Id" class="font-normal">@swEl.Text</BbLabel> }
                </div>
            }
            break;

        case "select":
            {
                var selEl = el;
                var selPh = PropStr(selEl, "placeholder");
                var selVal = PropStr(selEl, "selected");
                var selOpts = selEl.Props.TryGetValue("options", out var so) && so is (string Value, string Label)[] sOpts ? sOpts : [];
                <BbSelect TValue="string" Value="@selVal" ValueChanged="@((string v) => OnSelectChanged(selEl, v))">
                    <BbSelectTrigger>
                        <BbSelectValue Placeholder="@selPh" />
                    </BbSelectTrigger>
                    <BbSelectContent>
                        @foreach (var opt in selOpts)
                        {
                            <BbSelectItem Value="@opt.Value" Text="@opt.Label" TValue="string">@opt.Label</BbSelectItem>
                        }
                    </BbSelectContent>
                </BbSelect>
            }
            break;

        case "radio-group":
            {
                var rgEl = el;
                var rgVal = PropStr(rgEl, "selected");
                var rgOpts = rgEl.Props.TryGetValue("options", out var ro) && ro is (string Value, string Label)[] rOpts ? rOpts : [];
                <BbRadioGroup Value="@rgVal" ValueChanged="@((string v) => OnSelectChanged(rgEl, v))" class="@Cx("space-y-2", rgEl.Css)">
                    @foreach (var opt in rgOpts)
                    {
                        var radioId = $"radio-{opt.Value}";
                        <div class="flex items-center space-x-2">
                            <BbRadioGroupItem Value="@opt.Value" id="@radioId" />
                            <BbLabel For="@radioId">@opt.Label</BbLabel>
                        </div>
                    }
                </BbRadioGroup>
            }
            break;

        case "slider":
            {
                var slVal = PropDouble(el, "value");
                var slMin = PropDouble(el, "min");
                var slMax = PropDouble(el, "max", 100);
                var slStep = PropDouble(el, "step", 1);
                <BbSlider Value="slVal" Min="slMin" Max="slMax" Step="slStep"
                          ValueChanged="@(v => OnSliderChanged(el, v))" class="@el.Css" />
            }
            break;

        case "numeric-input":
            {
                var niEl = el;
                var niVal = PropDouble(niEl, "value");
                var niStep = PropDouble(niEl, "step", 1);
                <BbNumericInput TValue="double" Value="niVal" Step="niStep" id="@niEl.Id" class="@niEl.Css"
                                ValueChanged="@(v => OnNumericChanged(niEl, v))" />
            }
            break;

        case "combobox":
            {
                var cmbEl = el;
                var cmbPh = PropStr(cmbEl, "placeholder");
                var cmbVal = PropStr(cmbEl, "selected");
                var cmbOpts = cmbEl.Props.TryGetValue("options", out var co) && co is (string Value, string Label)[] cOpts ? cOpts : [];
                <BbCombobox TValue="string" Value="@cmbVal" Placeholder="@cmbPh"
                            ValueChanged="@((string v) => OnSelectChanged(cmbEl, v))" class="@cmbEl.Css">
                    @foreach (var opt in cmbOpts)
                    {
                        <BbComboboxItem Value="@opt.Value" Text="@opt.Label" TValue="string" />
                    }
                </BbCombobox>
            }
            break;

        case "toggle":
            {
                var tglEl = el;
                var tglPressed = PropBool(tglEl, "pressed");
                var tglVariant = PropStr(tglEl, "variant");
                var tglIcon = PropIcon(tglEl, "icon");
                var tv = tglVariant == "outline" ? ToggleVariant.Outline : ToggleVariant.Default;
                <BbToggle Pressed="tglPressed" Variant="tv" class="@tglEl.Css"
                          PressedChanged="@(v => OnTogglePressed(tglEl, v))">
                    @if (tglIcon != null) { @RenderIcon(tglIcon, 16, tglEl.Text != null ? "mr-2" : null) }
                    @tglEl.Text
                </BbToggle>
            }
            break;

        case "toggle-group":
            {
                var tgEl = el;
                var tgVal = PropStr(tgEl, "selected");
                var tgVariant = PropStr(tgEl, "variant");
                var tgOpts = tgEl.Props.TryGetValue("options", out var tgo) && tgo is (string Value, string Label)[] tgOptsArr ? tgOptsArr : [];
                var tgv = tgVariant == "outline" ? ToggleVariant.Outline : ToggleVariant.Default;
                <BbToggleGroup TValue="string" Value="@tgVal" Variant="tgv" class="@tgEl.Css"
                               ValueChanged="@((string v) => OnSelectChanged(tgEl, v))">
                    @foreach (var opt in tgOpts)
                    {
                        <BbToggleGroupItem Value="@opt.Value" TValue="string">@opt.Label</BbToggleGroupItem>
                    }
                </BbToggleGroup>
            }
            break;

        // ── Layout ──────────────────────────────────────────────────
        case "separator":
            <BbSeparator class="@el.Css" />
            break;

        case "spacer":
            <div class="flex-1"></div>
            break;

        case "div":
            <div class="@el.Css">
                <ElementRenderer Elements="el.Children" />
            </div>
            break;

        case "row":
            <div class="@Cx("flex flex-wrap gap-2 items-center", el.Css)">
                <ElementRenderer Elements="el.Children" />
            </div>
            break;

        case "column":
            <div class="@Cx("flex flex-col gap-2", el.Css)">
                <ElementRenderer Elements="el.Children" />
            </div>
            break;

        case "grid":
            {
                var cols = PropInt(el, "columns", 2);
                <div class="@Cx($"grid sm:grid-cols-{cols} gap-4", el.Css)">
                    <ElementRenderer Elements="el.Children" />
                </div>
            }
            break;

        case "scroll":
            <div class="@Cx("overflow-auto flex-1", el.Css)">
                <ElementRenderer Elements="el.Children" />
            </div>
            break;

        case "accordion":
            {
                var accType = PropStr(el, "type");
                var accItems = el.Children.Where(c => c.Tag == "accordion-item").ToList();
                <BbAccordion Type="@(accType == "multiple" ? BlazorBlueprint.Primitives.AccordionType.Multiple : BlazorBlueprint.Primitives.AccordionType.Single)" class="@Cx("w-full", el.Css)">
                    @foreach (var item in accItems)
                    {
                        var accVal = PropStr(item, "value") ?? item.Text ?? "";
                        <BbAccordionItem Value="@accVal">
                            <BbAccordionTrigger>@item.Text</BbAccordionTrigger>
                            <BbAccordionContent>
                                <ElementRenderer Elements="item.Children" />
                            </BbAccordionContent>
                        </BbAccordionItem>
                    }
                </BbAccordion>
            }
            break;

        case "aspect-ratio":
            {
                var arRatio = PropDouble(el, "ratio", 16.0 / 9.0);
                <BbAspectRatio Ratio="arRatio" class="@el.Css">
                    <ElementRenderer Elements="el.Children" />
                </BbAspectRatio>
            }
            break;

        // ── Cards ───────────────────────────────────────────────────
        case "card":
            <BbCard class="@el.Css">
                <ElementRenderer Elements="el.Children" />
            </BbCard>
            break;

        case "card-header":
            <BbCardHeader>
                <ElementRenderer Elements="el.Children" />
            </BbCardHeader>
            break;

        case "card-title":
            <BbCardTitle>@el.Text</BbCardTitle>
            break;

        case "card-description":
            <BbCardDescription>@el.Text</BbCardDescription>
            break;

        case "card-content":
            <BbCardContent class="space-y-6">
                <ElementRenderer Elements="el.Children" />
            </BbCardContent>
            break;

        case "card-footer":
            <BbCardFooter>
                <ElementRenderer Elements="el.Children" />
            </BbCardFooter>
            break;

        // ── Alerts ──────────────────────────────────────────────────
        case "alert":
            {
                var alertVariant = PropStr(el, "variant");
                var alertIcon = PropIcon(el, "icon");
                var av = alertVariant switch
                {
                    "danger" or "destructive" or "error" => AlertVariant.Danger,
                    "info" => AlertVariant.Info,
                    "success" => AlertVariant.Success,
                    "warning" => AlertVariant.Warning,
                    _ => AlertVariant.Default
                };
                @if (alertIcon != null)
                {
                    <BbAlert Variant="av" class="@el.Css">
                        <Icon>
                            @RenderIcon(alertIcon, 16)
                        </Icon>
                        <ChildContent>
                            <ElementRenderer Elements="el.Children" />
                        </ChildContent>
                    </BbAlert>
                }
                else
                {
                    <BbAlert Variant="av" class="@el.Css">
                        <ElementRenderer Elements="el.Children" />
                    </BbAlert>
                }
            }
            break;

        case "alert-title":
            <BbAlertTitle>@el.Text</BbAlertTitle>
            break;

        case "alert-description":
            <BbAlertDescription>@el.Text</BbAlertDescription>
            break;

        case "toast":
            {
                var toastTitle = PropStr(el, "title") ?? "";
                var toastDesc = PropStr(el, "description");
                var toastVariant = PropStr(el, "variant");
                var toastIcon = PropIcon(el, "icon");
                var toastCss = toastVariant == "destructive" ? "border-destructive bg-destructive/10" : "";
                <div class="@Cx("flex items-start gap-3 rounded-lg border p-4", Cx(toastCss, el.Css))">
                    @if (toastIcon != null) { @RenderIcon(toastIcon, 16, "mt-0.5 shrink-0") }
                    <div class="flex-1 space-y-1">
                        <p class="text-sm font-semibold">@toastTitle</p>
                        @if (toastDesc != null) { <p class="text-sm text-muted-foreground">@toastDesc</p> }
                    </div>
                </div>
            }
            break;

        // ── Links ───────────────────────────────────────────────────
        case "link":
            {
                var href = PropStr(el, "href") ?? "#";
                var ic = PropIcon(el, "icon");
                var desc = PropStr(el, "description");
                <a href="@href" target="_blank" class="@Cx("group block space-y-2 rounded-lg border p-4 hover:bg-accent transition-colors", el.Css)">
                    <div class="flex items-center gap-2">
                        @if (ic != null) { @RenderIcon(ic, 20, "text-primary") }
                        <h3 class="font-semibold">@el.Text</h3>
                    </div>
                    @if (desc != null)
                    {
                        <p class="text-sm text-muted-foreground">@desc</p>
                    }
                </a>
            }
            break;

        // ── Tabs ────────────────────────────────────────────────────
        case "tabs":
            {
                var tabChildren = el.Children.Where(c => c.Tag == "tab").ToList();
                var firstTab = tabChildren.FirstOrDefault()?.Text?.ToLowerInvariant().Replace(" ", "-") ?? "";
                <BbTabs DefaultValue="@firstTab" class="@Cx("w-full", el.Css)">
                    <BbTabsList class="@($"grid w-full grid-cols-{tabChildren.Count}")">
                        @foreach (var tab in tabChildren)
                        {
                            var tabVal = tab.Text?.ToLowerInvariant().Replace(" ", "-") ?? "";
                            var tabIcon = PropIcon(tab, "icon");
                            <BbTabsTrigger Value="@tabVal">
                                @if (tabIcon != null) { @RenderIcon(tabIcon, 14, "mr-1.5") }
                                @tab.Text
                            </BbTabsTrigger>
                        }
                    </BbTabsList>
                    @foreach (var tab in tabChildren)
                    {
                        var tabVal = tab.Text?.ToLowerInvariant().Replace(" ", "-") ?? "";
                        <BbTabsContent Value="@tabVal">
                            <ElementRenderer Elements="tab.Children" />
                        </BbTabsContent>
                    }
                </BbTabs>
            }
            break;

        // ── Collapsible ─────────────────────────────────────────────
        case "collapsible":
            {
                var collEl = el;
                var collExpanded = PropBool(collEl, "expanded");
                <BbCollapsible Open="collExpanded" OpenChanged="@(v => OnExpandedChanged(collEl, v))"
                               class="@Cx("space-y-2", collEl.Css)">
                    <div class="flex items-center justify-between space-x-4">
                        <h4 class="text-sm font-semibold">@collEl.Text</h4>
                        <BbCollapsibleTrigger>
                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" class="w-9 p-0">
                                <LucideIcon Name="chevrons-up-down" Size="16" />
                            </BbButton>
                        </BbCollapsibleTrigger>
                    </div>
                    <BbCollapsibleContent>
                        <ElementRenderer Elements="collEl.Children" />
                    </BbCollapsibleContent>
                </BbCollapsible>
            }
            break;

        // ── Dialog ──────────────────────────────────────────────────
        case "dialog":
            {
                var dlgEl = el;
                var dlgOpen = PropBool(dlgEl, "open");
                var dlgTrigger = PropStr(dlgEl, "triggerLabel") ?? "Open";
                var dlgTv = MapButtonVariant(PropStr(dlgEl, "triggerVariant"));
                <BbDialog Open="dlgOpen" OpenChanged="@(v => OnOpenChanged(dlgEl, v))">
                    <BbDialogTrigger>
                        <BbButton Variant="dlgTv">@dlgTrigger</BbButton>
                    </BbDialogTrigger>
                    <BbDialogContent>
                        @{
                            var dlgHasHeader = dlgEl.Children.Any(c => c.Tag is "dialog-title" or "dialog-description");
                        }
                        @if (dlgHasHeader)
                        {
                            <BbDialogHeader>
                                @foreach (var ch in dlgEl.Children.Where(c => c.Tag == "dialog-title"))
                                {
                                    <BbDialogTitle>@ch.Text</BbDialogTitle>
                                }
                                @foreach (var ch in dlgEl.Children.Where(c => c.Tag == "dialog-description"))
                                {
                                    <BbDialogDescription>@ch.Text</BbDialogDescription>
                                }
                            </BbDialogHeader>
                        }
                        @foreach (var ch in dlgEl.Children.Where(c => c.Tag == "dialog-content"))
                        {
                            <div class="py-4">
                                <ElementRenderer Elements="ch.Children" />
                            </div>
                        }
                        @foreach (var ch in dlgEl.Children.Where(c => c.Tag == "dialog-footer"))
                        {
                            <BbDialogFooter>
                                <ElementRenderer Elements="ch.Children" />
                            </BbDialogFooter>
                        }
                    </BbDialogContent>
                </BbDialog>
            }
            break;

        // ── Alert Dialog ────────────────────────────────────────────
        case "alert-dialog":
            {
                var adEl = el;
                var adOpen = PropBool(adEl, "open");
                var adTrigger = PropStr(adEl, "triggerLabel") ?? "Open";
                var adTv = MapButtonVariant(PropStr(adEl, "triggerVariant"));
                var adCancel = PropStr(adEl, "cancelText") ?? "Cancel";
                var adConfirm = PropStr(adEl, "confirmText") ?? "Continue";
                <BbAlertDialog Open="adOpen" OpenChanged="@(v => OnOpenChanged(adEl, v))">
                    <BbAlertDialogTrigger>
                        <BbButton Variant="adTv">@adTrigger</BbButton>
                    </BbAlertDialogTrigger>
                    <BbAlertDialogContent>
                        <BbAlertDialogHeader>
                            @foreach (var ch in adEl.Children.Where(c => c.Tag == "alert-dialog-title"))
                            {
                                <BbAlertDialogTitle>@ch.Text</BbAlertDialogTitle>
                            }
                            @foreach (var ch in adEl.Children.Where(c => c.Tag == "alert-dialog-description"))
                            {
                                <BbAlertDialogDescription>@ch.Text</BbAlertDialogDescription>
                            }
                        </BbAlertDialogHeader>
                        <BbAlertDialogFooter>
                            <BbAlertDialogCancel>
                                <BbButton Variant="ButtonVariant.Outline">@adCancel</BbButton>
                            </BbAlertDialogCancel>
                            <BbAlertDialogAction>
                                <BbButton Variant="ButtonVariant.Destructive" @onclick="() => adEl.OnClick?.Invoke()">@adConfirm</BbButton>
                            </BbAlertDialogAction>
                        </BbAlertDialogFooter>
                    </BbAlertDialogContent>
                </BbAlertDialog>
            }
            break;

        // ── Tooltip ─────────────────────────────────────────────────
        case "tooltip":
            {
                var tipText = el.Text ?? "";
                var tipSide = PropStr(el, "side");
                var tipTrigger = el.Props.TryGetValue("trigger", out var tt) && tt is List<Element> ttList ? ttList : [];
                <BbTooltipProvider>
                    <BbTooltip>
                        <BbTooltipTrigger>
                            <ElementRenderer Elements="tipTrigger" />
                        </BbTooltipTrigger>
                        <BbTooltipContent Side="@MapSide(tipSide)">
                            <p>@tipText</p>
                        </BbTooltipContent>
                    </BbTooltip>
                </BbTooltipProvider>
            }
            break;

        // ── Dropdown Menu ──────────────────────────────────────────
        case "dropdown-menu":
            {
                var dmEl = el;
                var dmTrigger = dmEl.Text ?? "Menu";
                var dmTv = MapButtonVariant(PropStr(dmEl, "triggerVariant"));
                var dmIcon = PropIcon(dmEl, "triggerIcon");
                <BbDropdownMenu>
                    <BbDropdownMenuTrigger>
                        <BbButton Variant="dmTv">
                            @if (dmIcon != null) { @RenderIcon(dmIcon, 16, "mr-2") }
                            @dmTrigger
                        </BbButton>
                    </BbDropdownMenuTrigger>
                    <BbDropdownMenuContent>
                        @RenderMenuChildren(dmEl.Children)
                    </BbDropdownMenuContent>
                </BbDropdownMenu>
            }
            break;

        // ── Context Menu ───────────────────────────────────────────
        case "context-menu":
            {
                var cmTrigger = el.Props.TryGetValue("trigger", out var cmt) && cmt is List<Element> cmtList ? cmtList : [];
                <BbContextMenu>
                    <BbContextMenuTrigger>
                        <ElementRenderer Elements="cmTrigger" />
                    </BbContextMenuTrigger>
                    <BbContextMenuContent>
                        @RenderMenuChildren(el.Children)
                    </BbContextMenuContent>
                </BbContextMenu>
            }
            break;

        // ── Popover ────────────────────────────────────────────────
        case "popover":
            {
                var popTrigger = el.Props.TryGetValue("trigger", out var pt) && pt is List<Element> ptList ? ptList : [];
                var popContent = el.Props.TryGetValue("content", out var pc) && pc is List<Element> pcList ? pcList : [];
                <BbPopover>
                    <BbPopoverTrigger>
                        <ElementRenderer Elements="popTrigger" />
                    </BbPopoverTrigger>
                    <BbPopoverContent class="@el.Css">
                        <ElementRenderer Elements="popContent" />
                    </BbPopoverContent>
                </BbPopover>
            }
            break;

        // ── Hover Card ─────────────────────────────────────────────
        case "hover-card":
            {
                var hcTrigger = el.Props.TryGetValue("trigger", out var hct) && hct is List<Element> hctList ? hctList : [];
                var hcContent = el.Props.TryGetValue("content", out var hcc) && hcc is List<Element> hccList ? hccList : [];
                <BbHoverCard>
                    <BbHoverCardTrigger>
                        <ElementRenderer Elements="hcTrigger" />
                    </BbHoverCardTrigger>
                    <BbHoverCardContent class="@el.Css">
                        <ElementRenderer Elements="hcContent" />
                    </BbHoverCardContent>
                </BbHoverCard>
            }
            break;

        // ── Drawer ─────────────────────────────────────────────────
        case "drawer":
            {
                var drEl = el;
                var drOpen = PropBool(drEl, "open");
                var drTrigger = PropStr(drEl, "triggerLabel") ?? "Open";
                var drTv = MapButtonVariant(PropStr(drEl, "triggerVariant"));
                var drDir = MapDrawerDirection(PropStr(drEl, "direction"));
                <BbDrawer Open="drOpen" OpenChanged="@(v => OnOpenChanged(drEl, v))" Direction="drDir">
                    <BbDrawerTrigger>
                        <BbButton Variant="drTv">@drTrigger</BbButton>
                    </BbDrawerTrigger>
                    <BbDrawerContent>
                        @{
                            var drHasHeader = drEl.Children.Any(c => c.Tag is "drawer-title" or "drawer-description");
                        }
                        @if (drHasHeader)
                        {
                            <BbDrawerHeader>
                                @foreach (var ch in drEl.Children.Where(c => c.Tag == "drawer-title"))
                                {
                                    <BbDrawerTitle>@ch.Text</BbDrawerTitle>
                                }
                                @foreach (var ch in drEl.Children.Where(c => c.Tag == "drawer-description"))
                                {
                                    <BbDrawerDescription>@ch.Text</BbDrawerDescription>
                                }
                            </BbDrawerHeader>
                        }
                        @foreach (var ch in drEl.Children.Where(c => c.Tag == "drawer-content"))
                        {
                            <div class="py-4 px-4">
                                <ElementRenderer Elements="ch.Children" />
                            </div>
                        }
                        @foreach (var ch in drEl.Children.Where(c => c.Tag == "drawer-footer"))
                        {
                            <BbDrawerFooter>
                                <ElementRenderer Elements="ch.Children" />
                            </BbDrawerFooter>
                        }
                    </BbDrawerContent>
                </BbDrawer>
            }
            break;

        // ── Sheet ──────────────────────────────────────────────────
        case "sheet":
            {
                var shEl = el;
                var shOpen = PropBool(shEl, "open");
                var shTrigger = PropStr(shEl, "triggerLabel") ?? "Open";
                var shTv = MapButtonVariant(PropStr(shEl, "triggerVariant"));
                var shSide = MapSheetSide(PropStr(shEl, "side"));
                <BbSheet Open="shOpen" OpenChanged="@(v => OnOpenChanged(shEl, v))" Side="shSide">
                    <BbSheetTrigger>
                        <BbButton Variant="shTv">@shTrigger</BbButton>
                    </BbSheetTrigger>
                    <BbSheetContent>
                        @{
                            var shHasHeader = shEl.Children.Any(c => c.Tag is "sheet-title" or "sheet-description");
                        }
                        @if (shHasHeader)
                        {
                            <BbSheetHeader>
                                @foreach (var ch in shEl.Children.Where(c => c.Tag == "sheet-title"))
                                {
                                    <BbSheetTitle>@ch.Text</BbSheetTitle>
                                }
                                @foreach (var ch in shEl.Children.Where(c => c.Tag == "sheet-description"))
                                {
                                    <BbSheetDescription>@ch.Text</BbSheetDescription>
                                }
                            </BbSheetHeader>
                        }
                        @foreach (var ch in shEl.Children.Where(c => c.Tag == "sheet-content"))
                        {
                            <div class="py-4">
                                <ElementRenderer Elements="ch.Children" />
                            </div>
                        }
                        @foreach (var ch in shEl.Children.Where(c => c.Tag == "sheet-footer"))
                        {
                            <BbSheetFooter>
                                <ElementRenderer Elements="ch.Children" />
                            </BbSheetFooter>
                        }
                    </BbSheetContent>
                </BbSheet>
            }
            break;

        // ── Breadcrumb ─────────────────────────────────────────────
        case "breadcrumb":
            {
                <BbBreadcrumb class="@el.Css">
                    <BbBreadcrumbList>
                        @foreach (var ch in el.Children)
                        {
                            if (ch.Tag == "breadcrumb-separator")
                            {
                                <BbBreadcrumbSeparator />
                            }
                            else if (ch.Tag == "breadcrumb-item")
                            {
                                var bcHref = PropStr(ch, "href");
                                var bcIcon = PropIcon(ch, "icon");
                                <BbBreadcrumbItem>
                                    @if (bcHref != null)
                                    {
                                        <BbBreadcrumbLink Href="@bcHref">
                                            @if (bcIcon != null) { @RenderIcon(bcIcon, 14, "mr-1") }
                                            @ch.Text
                                        </BbBreadcrumbLink>
                                    }
                                    else
                                    {
                                        <BbBreadcrumbPage>
                                            @if (bcIcon != null) { @RenderIcon(bcIcon, 14, "mr-1") }
                                            @ch.Text
                                        </BbBreadcrumbPage>
                                    }
                                </BbBreadcrumbItem>
                            }
                        }
                    </BbBreadcrumbList>
                </BbBreadcrumb>
            }
            break;

        // ── Pagination ─────────────────────────────────────────────
        case "pagination":
            {
                var pgEl = el;
                var pgCurrent = PropInt(pgEl, "currentPage", 1);
                var pgTotal = PropInt(pgEl, "totalPages", 1);
                <BbPagination class="@pgEl.Css">
                    <BbPaginationContent>
                        <BbPaginationItem>
                            <BbPaginationPrevious Disabled="@(pgCurrent <= 1)"
                                @onclick="() => OnPageNav(pgEl, pgCurrent - 1)" />
                        </BbPaginationItem>
                        @for (var i = 1; i <= pgTotal; i++)
                        {
                            var page = i;
                            <BbPaginationItem>
                                <BbPaginationLink IsActive="@(page == pgCurrent)"
                                    @onclick="() => OnPageNav(pgEl, page)">@(page)</BbPaginationLink>
                            </BbPaginationItem>
                        }
                        <BbPaginationItem>
                            <BbPaginationNext Disabled="@(pgCurrent >= pgTotal)"
                                @onclick="() => OnPageNav(pgEl, pgCurrent + 1)" />
                        </BbPaginationItem>
                    </BbPaginationContent>
                </BbPagination>
            }
            break;

        // ── Editor: Tree Item ───────────────────────────────────────
        case "tree-item":
            {
                var ic = PropIcon(el, "icon");
                var sel = PropBool(el, "selected");
                var exp = PropBool(el, "expanded", true);
                var icColor = PropStr(el, "iconColor");
                var hasChildren = el.Children.Count > 0;
                <div>
                    <div class="@Cx("flex items-center gap-1.5 h-6 px-1.5 rounded-sm cursor-pointer", sel ? "bg-accent" : "hover:bg-accent/50")"
                         @onclick="() => el.OnClick?.Invoke()">
                        @if (hasChildren)
                        {
                            <LucideIcon Name="@(exp ? "chevron-down" : "chevron-right")" Size="10" class="text-muted-foreground/50" />
                        }
                        else
                        {
                            <span class="w-2.5"></span>
                        }
                        @if (ic != null)
                        {
                            @RenderIcon(ic, 12, icColor ?? "text-muted-foreground")
                        }
                        <span class="@(sel ? "text-foreground" : "text-muted-foreground") text-[11px]">@el.Text</span>
                    </div>
                    @if (hasChildren && exp)
                    {
                        <div class="ml-3 border-l border-border/20 pl-1">
                            <ElementRenderer Elements="el.Children" />
                        </div>
                    }
                </div>
            }
            break;

        // ── Editor: Field Row ───────────────────────────────────────
        case "field-row":
            <div class="flex items-center gap-2 h-6 text-[11px]">
                <span class="w-28 shrink-0 text-muted-foreground truncate text-right pr-2">@el.Text</span>
                <div class="flex-1 min-w-0">
                    <ElementRenderer Elements="el.Children" />
                </div>
            </div>
            break;

        // ── Editor: Empty State ─────────────────────────────────────
        case "empty-state":
            {
                var ic = PropIcon(el, "icon");
                var title = PropStr(el, "title");
                var desc = PropStr(el, "description");
                <div class="flex-1 flex flex-col items-center justify-center gap-1.5 text-muted-foreground/30 p-6">
                    @if (ic != null) { @RenderIcon(ic, 24, "opacity-40") }
                    @if (title != null) { <span class="text-[11px] text-muted-foreground/40">@title</span> }
                    @if (desc != null) { <span class="text-[10px] text-muted-foreground/30">@desc</span> }
                </div>
            }
            break;

        // ── Editor: Log Entry ───────────────────────────────────────
        case "log-entry":
            {
                var level = PropStr(el, "level") ?? "INFO";
                var rowCss = level switch { "ERROR" or "FATAL" => "bg-destructive/5", "WARN" => "bg-yellow-500/5", _ => "" };
                var iconName = level switch { "ERROR" or "FATAL" => "circle-x", "WARN" => "triangle-alert", "DEBUG" or "TRACE" => "bug", _ => "info" };
                var iconCss = level switch { "ERROR" or "FATAL" => "text-destructive", "WARN" => "text-yellow-500", "DEBUG" or "TRACE" => "text-muted-foreground/30", _ => "text-blue-500/60" };
                <div class="@Cx("flex items-start gap-0 px-2 hover:bg-accent/30 border-b border-border/10 font-mono text-[10px] leading-5", rowCss)">
                    <span class="shrink-0 w-14 text-right pr-2 text-muted-foreground/40 py-px">@PropStr(el, "time")</span>
                    <span class="shrink-0 w-4 py-px"><LucideIcon Name="@iconName" Size="10" class="@iconCss" /></span>
                    <span class="shrink-0 text-muted-foreground/40 pr-1.5 py-px">@PropStr(el, "category")</span>
                    <span class="break-all min-w-0 py-px">@PropStr(el, "message")</span>
                </div>
            }
            break;

        // ── Dark Mode Toggle ──────────────────────────────────────────
        case "dark-mode-toggle":
            {
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" class="@el.Css"
                          @onclick="async () => await ToggleDarkMode()">
                    <LucideIcon Name="@(_isDarkMode ? "sun" : "moon")" Size="20" />
                </BbButton>
            }
            break;

        // ── Fallback ────────────────────────────────────────────────
        case "menubar":
            {
                var mbDesc = el.Props.TryGetValue("descriptor", out var mbD) && mbD is MenubarDescriptor mbd ? mbd : null;
                if (mbDesc is { Menus.Count: > 0 })
                {
                    <BbMenubar class="@el.Css">
                        @foreach (var menu in mbDesc.Menus)
                        {
                            <BbMenubarMenu>
                                <BbMenubarTrigger>@menu.Label</BbMenubarTrigger>
                                <BbMenubarContent>
                                    @RenderMenuChildren(menu.Items)
                                </BbMenubarContent>
                            </BbMenubarMenu>
                        }
                    </BbMenubar>
                }
            }
            break;

        case "navigation-menu":
            {
                var nmDesc = el.Props.TryGetValue("descriptor", out var nmD) && nmD is NavigationMenuDescriptor nmd ? nmd : null;
                if (nmDesc is { Groups.Count: > 0 })
                {
                    <BbNavigationMenu class="@el.Css">
                        <BbNavigationMenuList>
                            @foreach (var group in nmDesc.Groups)
                            {
                                @if (group.Title != null)
                                {
                                    <BbNavigationMenuItem>
                                        <BbNavigationMenuTrigger>@group.Title</BbNavigationMenuTrigger>
                                        <BbNavigationMenuContent>
                                            <ul class="grid w-[400px] gap-3 p-4 md:w-[500px] md:grid-cols-2 lg:w-[600px]">
                                                @foreach (var item in group.Items)
                                                {
                                                    <li>
                                                        <BbNavigationMenuLink Href="@item.Href" class="block select-none space-y-1 rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground">
                                                            <div class="flex items-center gap-2">
                                                                @if (!string.IsNullOrEmpty(item.Icon))
                                                                {
                                                                    @RenderIcon(item.Icon, 16, "text-primary")
                                                                }
                                                                <div class="text-sm font-medium leading-none">@item.Label</div>
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(item.Description))
                                                            {
                                                                <p class="line-clamp-2 text-sm leading-snug text-muted-foreground">@item.Description</p>
                                                            }
                                                        </BbNavigationMenuLink>
                                                    </li>
                                                }
                                            </ul>
                                        </BbNavigationMenuContent>
                                    </BbNavigationMenuItem>
                                }
                                else
                                {
                                    @foreach (var item in group.Items)
                                    {
                                        <BbNavigationMenuItem>
                                            <BbNavigationMenuLink Href="@item.Href">
                                                @if (!string.IsNullOrEmpty(item.Icon))
                                                {
                                                    @RenderIcon(item.Icon, 14, "mr-1.5")
                                                }
                                                @item.Label
                                            </BbNavigationMenuLink>
                                        </BbNavigationMenuItem>
                                    }
                                }
                            }
                        </BbNavigationMenuList>
                    </BbNavigationMenu>
                }
            }
            break;

        default:
            <div class="@el.Css">
                @if (el.Text != null) { <span>@el.Text</span> }
                @if (el.Children.Count > 0) { <ElementRenderer Elements="el.Children" /> }
            </div>
            break;
    }
}

@code {
    [Parameter, EditorRequired] public List<Element> Elements { get; set; } = [];
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private static bool _isDarkMode = true; // default dark

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _isDarkMode = await JS.InvokeAsync<bool>("isDarkModeEnabled"); } catch { }
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        await JS.InvokeVoidAsync("toggleDarkMode");
        _isDarkMode = !_isDarkMode;
    }

    private static string Cx(string baseClass, string? extra) =>
        string.IsNullOrEmpty(extra) ? baseClass : $"{baseClass} {extra}";

    private static string? PropStr(Element el, string key) =>
        el.Props.TryGetValue(key, out var v) ? v?.ToString() : null;

    private static int PropInt(Element el, string key, int fallback = 0) =>
        el.Props.TryGetValue(key, out var v) && v is int i ? i : fallback;

    private static bool PropBool(Element el, string key, bool fallback = false) =>
        el.Props.TryGetValue(key, out var v) && v is bool b ? b : fallback;

    private static string? PropIcon(Element el, string key) =>
        el.Props.TryGetValue(key, out var v) && v is string s && !string.IsNullOrEmpty(s) ? s : null;

    private static double PropDouble(Element el, string key, double fallback = 0) =>
        el.Props.TryGetValue(key, out var v) ? v switch { double d => d, int i => i, float f => f, _ => fallback } : fallback;

    public static RenderFragment RenderIcon(string? icon, int size, string? css = null) => builder =>
    {
        if (string.IsNullOrEmpty(icon)) return;
        builder.OpenComponent<LucideIcon>(0);
        builder.AddAttribute(1, "Name", icon);
        builder.AddAttribute(2, "Size", size);
        if (css != null) builder.AddAttribute(3, "class", css);
        builder.CloseComponent();
    };

    private static ButtonVariant MapButtonVariant(string? v) => v switch
    {
        "secondary" => ButtonVariant.Secondary,
        "outline" => ButtonVariant.Outline,
        "ghost" => ButtonVariant.Ghost,
        "destructive" => ButtonVariant.Destructive,
        "link" => ButtonVariant.Link,
        _ => ButtonVariant.Default
    };

    private static PopoverSide MapSide(string? s) => s switch
    {
        "bottom" => PopoverSide.Bottom,
        "left" => PopoverSide.Left,
        "right" => PopoverSide.Right,
        _ => PopoverSide.Top
    };

    private static BlazorBlueprint.Primitives.SheetSide MapSheetSide(string? s) => s switch
    {
        "top" => BlazorBlueprint.Primitives.SheetSide.Top,
        "bottom" => BlazorBlueprint.Primitives.SheetSide.Bottom,
        "left" => BlazorBlueprint.Primitives.SheetSide.Left,
        _ => BlazorBlueprint.Primitives.SheetSide.Right
    };

    private static DrawerDirection MapDrawerDirection(string? s) => s switch
    {
        "top" => DrawerDirection.Top,
        "left" => DrawerDirection.Left,
        "right" => DrawerDirection.Right,
        _ => DrawerDirection.Bottom
    };

    private void OnCheckedChanged(Element el, bool value)
    {
        el.Props["checked"] = value;
        el.OnToggle?.Invoke(value);
    }

    private void OnSelectChanged(Element el, string value)
    {
        el.Props["selected"] = value;
        el.OnInput?.Invoke(value);
    }

    private void OnExpandedChanged(Element el, bool value)
    {
        el.Props["expanded"] = value;
    }

    private void OnOpenChanged(Element el, bool value)
    {
        el.Props["open"] = value;
    }

    private void OnSliderChanged(Element el, double value)
    {
        el.Props["value"] = value;
        el.OnValueChanged?.Invoke(value);
    }

    private void OnNumericChanged(Element el, double value)
    {
        el.Props["value"] = value;
        el.OnValueChanged?.Invoke(value);
    }

    private void OnTogglePressed(Element el, bool value)
    {
        el.Props["pressed"] = value;
        el.OnToggle?.Invoke(value);
    }

    private void OnPageNav(Element el, int page)
    {
        var total = PropInt(el, "totalPages", 1);
        var clamped = Math.Clamp(page, 1, total);
        el.Props["currentPage"] = clamped;
        el.OnIndexChanged?.Invoke(clamped);
    }

    private RenderFragment RenderMenuChildren(List<Element> children) => builder =>
    {
        var seq = 0;
        foreach (var ch in children)
        {
            switch (ch.Tag)
            {
                case "menu-label":
                    builder.OpenComponent<BbDropdownMenuLabel>(seq++);
                    builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(b => b.AddContent(0, ch.Text)));
                    builder.CloseComponent();
                    break;

                case "menu-separator":
                    builder.OpenComponent<BbDropdownMenuSeparator>(seq++);
                    builder.CloseComponent();
                    break;

                case "menu-item":
                    var miIcon = PropIcon(ch, "icon");
                    var miShortcut = PropStr(ch, "shortcut");
                    var miDisabled = PropBool(ch, "disabled");
                    var miCh = ch;
                    builder.OpenComponent<BbDropdownMenuItem>(seq++);
                    if (miDisabled) builder.AddAttribute(seq++, "Disabled", true);
                    builder.AddAttribute(seq++, "OnClick",
                        Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, () => miCh.OnClick?.Invoke()));
                    builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(b =>
                    {
                        if (miIcon != null) { b.AddContent(0, RenderIcon(miIcon, 16, "mr-2")); }
                        b.AddContent(1, miCh.Text);
                        if (miShortcut != null)
                        {
                            b.OpenElement(2, "span");
                            b.AddAttribute(3, "class", "ml-auto text-xs text-muted-foreground");
                            b.AddContent(4, miShortcut);
                            b.CloseElement();
                        }
                    }));
                    builder.CloseComponent();
                    break;

                case "menu-checkbox-item":
                    var mciCh = ch;
                    var mciChecked = PropBool(ch, "checked");
                    builder.OpenComponent<BbDropdownMenuCheckboxItem>(seq++);
                    builder.AddAttribute(seq++, "Checked", mciChecked);
                    builder.AddAttribute(seq++, "CheckedChanged",
                        Microsoft.AspNetCore.Components.EventCallback.Factory.Create<bool>(this, v =>
                        {
                            mciCh.Props["checked"] = v;
                            mciCh.OnToggle?.Invoke(v);
                        }));
                    builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(b => b.AddContent(0, mciCh.Text)));
                    builder.CloseComponent();
                    break;

                case "menu-sub":
                    // Sub-menus rendered as a labeled group with nested items
                    var subCh = ch;
                    var subIcon = PropIcon(ch, "icon");
                    builder.OpenComponent<BbDropdownMenuLabel>(seq++);
                    builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(b =>
                    {
                        if (subIcon != null) { b.AddContent(0, RenderIcon(subIcon, 16, "mr-2")); }
                        b.AddContent(1, subCh.Text);
                    }));
                    builder.CloseComponent();
                    // Render sub-items inline
                    foreach (var subItem in subCh.Children)
                    {
                        if (subItem.Tag == "menu-item")
                        {
                            var si = subItem;
                            var siIcon = PropIcon(si, "icon");
                            builder.OpenComponent<BbDropdownMenuItem>(seq++);
                            builder.AddAttribute(seq++, "OnClick",
                                Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, () => si.OnClick?.Invoke()));
                            builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(b =>
                            {
                                if (siIcon != null) { b.AddContent(0, RenderIcon(siIcon, 16, "mr-2")); }
                                b.AddContent(1, $"  {si.Text}");
                            }));
                            builder.CloseComponent();
                        }
                        else if (subItem.Tag == "menu-separator")
                        {
                            builder.OpenComponent<BbDropdownMenuSeparator>(seq++);
                            builder.CloseComponent();
                        }
                    }
                    break;
            }
        }
    };
}
