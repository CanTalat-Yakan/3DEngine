@inherits LayoutComponentBase
@namespace Editor.Server.Shared

<div class="shell-root relative min-h-screen flex flex-col bg-background text-foreground">
    @{
        var topPanels = Descriptor.Panels
            .Where(p => p.Visible && p.DefaultZone == DockZone.Top)
            .OrderBy(p => p.TabOrder)
            .ToList();
    }

    @* ── Inject custom CSS from user scripts ─────────────────── *@
    @if (Descriptor.CustomCss.Count > 0)
    {
        <style>
            @foreach (var css in Descriptor.CustomCss)
            {
                @((MarkupString)css)
            }
        </style>
    }

    @foreach (var panel in topPanels)
    {
        @if (panel.ComponentType is not null)
        {
            <DynamicComponent Type="panel.ComponentType" />
        }
        else if (panel.Content is { Count: > 0 })
        {
            <ElementRenderer Elements="panel.Content" />
        }
    }

    <main class="flex-1">
        @Body
    </main>
</div>

<BbToastProvider Position="ToastPosition.BottomRight" />
<BbDialogProvider />
<BbPortalHost />
