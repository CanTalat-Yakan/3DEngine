@using Editor.Shell

@{
    var tabGroups = Panels
        .Where(p => p.TabGroupId != null)
        .GroupBy(p => p.TabGroupId!)
        .ToList();
    var standalonePanels = Panels.Where(p => p.TabGroupId == null).ToList();
}

<div class="flex flex-col flex-1 overflow-hidden min-h-0">
    @foreach (var panel in standalonePanels)
    {
        <DockPanel Panel="panel" />
    }

    @foreach (var group in tabGroups)
    {
        var orderedPanels = group.OrderBy(p => p.TabOrder).ToList();
        <div class="flex flex-col flex-1 overflow-hidden min-h-0">
            <BbTabs DefaultValue="@orderedPanels.First().Id" class="flex flex-col flex-1 overflow-hidden">
                <BbTabsList class="h-7 rounded-none border-b border-border/40 bg-background px-0 justify-start gap-0">
                    @foreach (var panel in orderedPanels)
                    {
                        <BbTabsTrigger Value="@panel.Id"
                                       class="h-7 rounded-none border-b-2 border-transparent text-[11px] px-3 text-muted-foreground data-[state=active]:text-foreground data-[state=active]:border-primary data-[state=active]:bg-transparent">
                            @if (panel.Icon != null)
                            {
                                <LucideIcon Name="@panel.Icon" Size="12" class="mr-1.5 opacity-60" />
                            }
                            @panel.Title
                        </BbTabsTrigger>
                    }
                </BbTabsList>
                @foreach (var panel in orderedPanels)
                {
                    <BbTabsContent Value="@panel.Id" class="flex-1 overflow-auto m-0 p-0 min-h-0">
                        @if (panel.Content is { Count: > 0 })
                        {
                            <ElementRenderer Elements="panel.Content" />
                        }
                        else
                        {
                            <div class="flex items-center justify-center h-full text-muted-foreground/30 text-[11px]">
                                @panel.Id
                            </div>
                        }
                    </BbTabsContent>
                }
            </BbTabs>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<PanelDescriptor> Panels { get; set; } = [];
}
