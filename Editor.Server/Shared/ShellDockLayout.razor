@using Editor.Shell

@{
    var topPanels = Panels.Where(p => p.Visible && p.DefaultZone == DockZone.Top).OrderBy(p => p.TabOrder).ToList();
    var leftPanels = Panels.Where(p => p.Visible && p.DefaultZone == DockZone.Left).ToList();
    var rightPanels = Panels.Where(p => p.Visible && p.DefaultZone == DockZone.Right).ToList();
    var bottomPanels = Panels.Where(p => p.Visible && p.DefaultZone == DockZone.Bottom).ToList();
    var centerPanels = Panels.Where(p => p.Visible && p.DefaultZone == DockZone.Center).ToList();
    var hasTop = leftPanels.Count > 0 || rightPanels.Count > 0 || centerPanels.Count > 0;
}

<div class="flex flex-col flex-1 overflow-hidden min-h-0">
    @* ── Top panels (headers, nav bars, etc.) ─────────────────── *@
    @foreach (var panel in topPanels)
    {
        @if (panel.ComponentType is not null)
        {
            <div class="shrink-0">
                <DynamicComponent Type="panel.ComponentType" />
            </div>
        }
        else if (panel.Content is { Count: > 0 })
        {
            <div class="shrink-0">
                <ElementRenderer Elements="panel.Content" />
            </div>
        }
    }

    @* ── Top row: sidebars fill the available horizontal space ── *@
    @if (hasTop)
    {
        <div class="flex flex-1 overflow-hidden min-h-0">
            @if (leftPanels.Count > 0)
            {
                <div class="flex flex-col overflow-hidden border-r border-border/40"
                     style="width: @(SizeOf(leftPanels)); min-width: 180px;">
                    <DockPanelGroup Panels="leftPanels" />
                </div>
            }

            @if (centerPanels.Count > 0)
            {
                <div class="flex-1 flex flex-col overflow-hidden min-w-0">
                    <DockPanelGroup Panels="centerPanels" />
                </div>
            }
            else
            {
                @* No embedded viewport - just let sidebars divide the space *@
                <div class="flex-1 min-w-0" />
            }

            @if (rightPanels.Count > 0)
            {
                <div class="flex flex-col overflow-hidden border-l border-border/40"
                     style="width: @(SizeOf(rightPanels)); min-width: 220px;">
                    <DockPanelGroup Panels="rightPanels" />
                </div>
            }
        </div>
    }

    @* ── Bottom panel strip ─────────────────────────────────── *@
    @if (bottomPanels.Count > 0)
    {
        <div class="overflow-hidden border-t border-border/40"
             style="height: @(HeightOf(bottomPanels)); min-height: 120px;">
            <DockPanelGroup Panels="bottomPanels" />
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<PanelDescriptor> Panels { get; set; } = [];

    private static string SizeOf(List<PanelDescriptor> panels)
    {
        var pct = (panels.FirstOrDefault()?.InitialSize ?? 0.25f) * 100f;
        return $"{Math.Clamp(pct, 12, 50):F0}%";
    }

    private static string HeightOf(List<PanelDescriptor> panels)
    {
        var pct = (panels.FirstOrDefault()?.InitialSize ?? 0.25f) * 100f;
        return $"{Math.Clamp(pct, 15, 50):F0}%";
    }
}
