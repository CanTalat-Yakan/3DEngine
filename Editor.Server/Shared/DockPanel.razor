@using Editor.Shell

<div class="flex flex-col flex-1 overflow-hidden min-h-0">
    @* Panel header - only shown when not a headerless center panel *@
    @if (Panel.DefaultZone != DockZone.Center || Panel.Closeable)
    {
        <div class="flex items-center h-7 border-b border-border/40 bg-background px-2 shrink-0 gap-1.5">
        @if (!string.IsNullOrEmpty(Panel.Icon))
        {
            @ElementRenderer.RenderIcon(Panel.Icon, 12, "text-muted-foreground opacity-60")
        }
            <span class="text-[11px] font-medium text-foreground/80">@Panel.Title</span>
            <div class="flex-1" />
            @if (Panel.Closeable)
            {
                <button class="h-4 w-4 inline-flex items-center justify-center rounded-sm text-muted-foreground/40 hover:text-foreground hover:bg-accent transition-colors cursor-pointer"
                        @onclick="() => Panel.Visible = false">
                    <LucideIcon Name="x" Size="10" />
                </button>
            }
        </div>
    }

    @* Panel content *@
    <div class="flex-1 overflow-auto min-h-0">
        @if (Panel.ComponentType is not null)
        {
            <DynamicComponent Type="Panel.ComponentType" />
        }
        else if (Panel.Content is { Count: > 0 })
        {
            <ElementRenderer Elements="Panel.Content" />
        }
        else
        {
            <div class="flex items-center justify-center h-full text-muted-foreground/30 text-[11px]">
                @Panel.Id
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PanelDescriptor Panel { get; set; } = null!;
}
