@using Editor.Shell
@attribute [EditorPanel("blazor-demo", "Blazor Demo", DockZone.Center, Route = "/blazor-demo", TabGroup = "showcase", TabOrder = 1, Icon = "code")]

<div class="container py-10">
    <div class="mx-auto max-w-3xl space-y-8">
        @* ── Hero ─────────────────────────────────────────────── *@
        <div class="text-center space-y-4">
            <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold text-muted-foreground">
                Native Blazor Component
            </span>
            <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
                Hello from a .razor file!
            </h1>
            <p class="text-xl text-muted-foreground">
                This panel is a native Blazor component compiled at runtime.
                Full Blazor features: <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">@@onclick</code>,
                <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">@@bind</code>,
                <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">@@inject</code>, and more.
            </p>
        </div>

        @* ── Interactive Counter Demo ─────────────────────────── *@
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="text-2xl font-semibold leading-none tracking-tight">Interactive Counter</h3>
                <p class="text-sm text-muted-foreground">
                    Demonstrates @@onclick event handling — impossible with the C#-only builder API.
                </p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                <div class="flex items-center gap-4">
                    <button class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2"
                            @onclick="Increment">
                        Count: @count
                    </button>
                    <button class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2"
                            @onclick="Reset">
                        Reset
                    </button>
                </div>
                <p class="text-sm text-muted-foreground">
                    Clicked <strong>@count</strong> time(s).
                </p>
            </div>
        </div>

        @* ── Two-way Binding Demo ─────────────────────────────── *@
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="text-2xl font-semibold leading-none tracking-tight">Two-Way Binding</h3>
                <p class="text-sm text-muted-foreground">
                    Demonstrates @@bind for live text input.
                </p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                <div class="space-y-2">
                    <label class="text-sm font-medium leading-none">Your name</label>
                    <input class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                           placeholder="Type your name..."
                           @bind="userName"
                           @bind:event="oninput" />
                </div>
                @if (!string.IsNullOrEmpty(userName))
                {
                    <div class="rounded-lg border p-4">
                        <p class="text-sm">Hello, <strong>@userName</strong>! 👋</p>
                    </div>
                }
            </div>
        </div>

        @* ── Info ─────────────────────────────────────────────── *@
        <div class="rounded-lg border p-4 space-y-2">
            <p class="text-sm font-semibold">How it works</p>
            <p class="text-sm text-muted-foreground">
                This <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">.razor</code> file is compiled
                at runtime by the <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">ShellCompiler</code>
                using <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">dotnet build</code>
                with the Razor SDK. The resulting component type is rendered via
                <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">DynamicComponent</code>.
                Hot-reload works — edit this file and the panel updates automatically.
            </p>
        </div>
    </div>
</div>

@code {
    private int count;
    private string userName = "";

    private void Increment() => count++;
    private void Reset() => count = 0;
}

